# Copy to .env (gitignored). docker compose reads it automatically.
# Your (rotated) NVIDIA NIM key enables live LLM drafting; without it the
# pipeline still runs and uses the template engine.
NIM_API_KEY=nvapi-your-rotated-key-here
# Optional: override the chat model served by NIM
# NIM_CHAT_MODEL=openai/gpt-oss-120b

# Operator API key for the console's protected endpoints (use a long random value).
AEGIS_API_KEY=change-me-to-a-long-random-string
# Comma-separated browser origins allowed to call the API.
AEGIS_ALLOWED_ORIGINS=http://localhost:8088

# Per-IP rate limits on the public endpoints (requests/minute).
# AEGIS_INTAKE_RATE=20
# AEGIS_STATUS_RATE=60

# PII retention: purge cases + audit events older than N days (0 = keep forever, dev only).
# Set a real policy (e.g. 365) before processing anything resembling real data.
# AEGIS_RETENTION_DAYS=0

# Customer email notifications. docker-compose routes mail into MailHog
# (inbox at http://localhost:8025); point SPRING_MAIL_* at real SMTP for prod.
# AEGIS_MAIL_ENABLED=true
# AEGIS_PUBLIC_BASE_URL=http://localhost:8088

# Only honor X-Forwarded-For behind a proxy/load balancer you control.
# AEGIS_TRUST_PROXY=false
