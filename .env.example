# Copy to .env (gitignored). docker compose reads it automatically.
# Your (rotated) NVIDIA NIM key enables live LLM drafting; without it the
# pipeline still runs and uses the template engine.
NIM_API_KEY=nvapi-your-rotated-key-here
# Optional: override the chat model served by NIM
# NIM_CHAT_MODEL=openai/gpt-oss-120b

# Operator API key for the console's protected endpoints (use a long random value).
AEGIS_API_KEY=change-me-to-a-long-random-string
# Comma-separated browser origins allowed to call the API.
AEGIS_ALLOWED_ORIGINS=http://localhost:8088
