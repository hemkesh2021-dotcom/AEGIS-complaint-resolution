{
  "realm": "aegis",
  "enabled": true,
  "displayName": "AEGIS Operators",
  "registrationAllowed": false,
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 28800,
  "roles": {
    "realm": [
      { "name": "operator", "description": "Work the queue, approve normal cases, send follow-ups" },
      { "name": "supervisor", "description": "Additionally approve CRITICAL / escalated cases (maker-checker)" }
    ]
  },
  "users": [
    {
      "username": "operator1",
      "enabled": true,
      "firstName": "Omar",
      "lastName": "Operator",
      "email": "operator1@aegis.local",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "operator", "temporary": false }],
      "realmRoles": ["operator"]
    },
    {
      "username": "supervisor1",
      "enabled": true,
      "firstName": "Sana",
      "lastName": "Supervisor",
      "email": "supervisor1@aegis.local",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "supervisor", "temporary": false }],
      "realmRoles": ["operator", "supervisor"]
    }
  ],
  "clients": [
    {
      "clientId": "aegis-console",
      "name": "AEGIS Operator Console",
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8088/*"],
      "webOrigins": ["http://localhost:8088"],
      "attributes": { "pkce.code.challenge.method": "S256", "post.logout.redirect.uris": "http://localhost:8088/*" }
    }
  ]
}
